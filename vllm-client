#!/bin/bash
# -*- mode: sh; indent-tabs-mode: nil; sh-basic-offset: 4 -*-
# vim: autoindent tabstop=4 shiftwidth=4 expandtab softtabstop=4 filetype=bash
exec >vllm-client-stderrout.txt 2>&1

. /usr/bin/vllm-base || exit 1

dump_runtime
validate_label
validate_sw_prereqs python3 guidellm

duration=60
profile="synchronous"
rate=""
max_requests=""
input_tokens=128
output_tokens=64
model=""

longopts="duration:,profile:,rate:,max-requests:"
longopts+=",input-tokens:,output-tokens:,model:"

opts=$(getopt -q -o "" --longoptions "$longopts" -n "getopt.sh" -- "$@")
if [ $? -ne 0 ]; then
    printf -- "\tUnrecognized option specified\n\n"
    exit 1
fi
eval set -- "$opts"
while true; do
    case "$1" in
        --duration)
            shift
            duration=$1
            shift
            ;;
        --profile)
            shift
            profile=$1
            shift
            ;;
        --rate)
            shift
            rate=$1
            shift
            ;;
        --max-requests)
            shift
            max_requests=$1
            shift
            ;;
        --input-tokens)
            shift
            input_tokens=$1
            shift
            ;;
        --output-tokens)
            shift
            output_tokens=$1
            shift
            ;;
        --model)
            shift
            model=$1
            shift
            ;;
        --)
            shift
            break
            ;;
        *)
            shift
            ;;
    esac
done

file="msgs/rx/endpoint-start-end:1"
if [ ! -e "${file}" ]; then
    file="msgs/rx/server-start-end:1"
fi
if [ -e "$file" ]; then
    remotehost=$(jq -r '.svc.ip' $file)
    port=$(jq -r '.svc.ports[0]' $file)
else
    exit_error "Could not find server service information"
fi

base_url="http://${remotehost}:${port}"

echo "Server: ${base_url}"
echo "Profile: ${profile}"
echo "Duration: ${duration}s"
echo "Input tokens: ${input_tokens}"
echo "Output tokens: ${output_tokens}"

guidellm_cmd="guidellm benchmark"
guidellm_cmd+=" --target ${base_url}"
guidellm_cmd+=" --profile kind=${profile}"
guidellm_cmd+=" --max-seconds ${duration}"
guidellm_cmd+=" --data kind=synthetic_text,prompt_tokens=${input_tokens},output_tokens=${output_tokens}"
guidellm_cmd+=" --output-dir ./guidellm-results"
guidellm_cmd+=" --outputs json"
guidellm_cmd+=" --random-seed 42"

if [ -n "$rate" ]; then
    guidellm_cmd+=" --rate $rate"
fi
if [ -n "$max_requests" ]; then
    guidellm_cmd+=" --max-requests $max_requests"
fi
if [ -n "$model" ]; then
    guidellm_cmd+=" --model $model"
fi

echo "Running: $guidellm_cmd"
date +%s.%N >begin.txt
$guidellm_cmd
rc=$?
date +%s.%N >end.txt
exit $rc
