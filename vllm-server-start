#!/bin/bash
# -*- mode: sh; indent-tabs-mode: nil; sh-basic-offset: 4 -*-
# vim: autoindent tabstop=4 shiftwidth=4 expandtab softtabstop=4 filetype=bash
exec >vllm-server-stderrout.txt 2>&1

. /usr/bin/vllm-base || exit 1

dump_runtime
validate_label

model="Qwen/Qwen2.5-1.5B-Instruct"
device="cpu"
port=8000
max_model_len=512
tensor_parallel_size=1
dtype="auto"
quantization=""
gpu_memory_utilization="0.90"

longopts="model:,device:,port:,max-model-len:,tensor-parallel-size:"
longopts+=",dtype:,quantization:,gpu-memory-utilization:"

opts=$(getopt -q -o "" --longoptions "$longopts" -n "getopt.sh" -- "$@")
if [ $? -ne 0 ]; then
    printf -- "\tUnrecognized option specified\n\n"
    exit 1
fi
eval set -- "$opts"
while true; do
    case "$1" in
        --model)
            shift
            model=$1
            shift
            ;;
        --device)
            shift
            device=$1
            shift
            ;;
        --port)
            shift
            port=$1
            shift
            ;;
        --max-model-len)
            shift
            max_model_len=$1
            shift
            ;;
        --tensor-parallel-size)
            shift
            tensor_parallel_size=$1
            shift
            ;;
        --dtype)
            shift
            dtype=$1
            shift
            ;;
        --quantization)
            shift
            quantization=$1
            shift
            ;;
        --gpu-memory-utilization)
            shift
            gpu_memory_utilization=$1
            shift
            ;;
        --)
            shift
            break
            ;;
        *)
            shift
            ;;
    esac
done

echo "model: $model"
echo "device: $device"
echo "port: $port"
echo "max-model-len: $max_model_len"
echo "tensor-parallel-size: $tensor_parallel_size"
echo "dtype: $dtype"

ip=$(hostname -I | awk '{print $1}')

echo '{"recipient":{"type":"all","id":"all"},"user-object":{"svc":{"ip":"'$ip'","ports":['$port']}}}' >msgs/tx/svc

vllm_cmd="python3 -m vllm.entrypoints.openai.api_server"
vllm_cmd+=" --model $model"
vllm_cmd+=" --port $port"
vllm_cmd+=" --max-model-len $max_model_len"
vllm_cmd+=" --dtype $dtype"

if [ "$device" == "cpu" ]; then
    vllm_cmd+=" --device cpu"
    echo "=== CPU MODE ==="
    validate_sw_prereqs python3 curl
else
    vllm_cmd+=" --tensor-parallel-size $tensor_parallel_size"
    vllm_cmd+=" --gpu-memory-utilization $gpu_memory_utilization"
    echo "=== GPU MODE ==="
    validate_sw_prereqs python3 nvidia-smi curl
fi

if [ -n "$quantization" ] && [ "$quantization" != "none" ]; then
    vllm_cmd+=" --quantization $quantization"
fi

echo "Starting vLLM server: $vllm_cmd"
$vllm_cmd >vllm-server-output.txt 2>&1 &
pid=$!
echo $pid >vllm-server.pid

if [ "$device" == "cpu" ]; then
    max_wait=600
else
    max_wait=300
fi

elapsed=0
while [ $elapsed -lt $max_wait ]; do
    if curl -s http://localhost:${port}/health >/dev/null 2>&1; then
        echo "vLLM server ready after ${elapsed}s (device=$device)"
        exit 0
    fi
    if ! kill -0 $pid 2>/dev/null; then
        echo "vLLM server process died during startup"
        cat vllm-server-output.txt
        exit_error "vLLM server failed to start"
    fi
    sleep 5
    elapsed=$((elapsed + 5))
done

exit_error "vLLM server not ready within ${max_wait}s"
