{
    "presets": {
        "cpu-smoke": [
            { "arg": "server-mode", "vals": ["mock"], "role": "server" },
            { "arg": "device", "vals": ["cpu"], "role": "server" },
            { "arg": "model", "vals": ["mock-model"], "role": "all" },
            { "arg": "dtype", "vals": ["float32"], "role": "server" },
            { "arg": "max-model-len", "vals": ["256"], "role": "server" },
            { "arg": "profile", "vals": ["synchronous"], "role": "client" },
            { "arg": "duration", "vals": ["30"], "role": "client" },
            { "arg": "input-tokens", "vals": ["64"], "role": "client" },
            { "arg": "output-tokens", "vals": ["32"], "role": "client" },
            { "arg": "tensor-parallel-size", "vals": ["1"], "role": "server" },
            { "arg": "port", "vals": ["8000"], "role": "server" }
        ],
        "cpu-functional": [
            { "arg": "server-mode", "vals": ["vllm"], "role": "server" },
            { "arg": "device", "vals": ["cpu"], "role": "server" },
            { "arg": "model", "vals": ["Qwen/Qwen2.5-1.5B-Instruct"], "role": "all" },
            { "arg": "dtype", "vals": ["float32"], "role": "server" },
            { "arg": "max-model-len", "vals": ["512"], "role": "server" },
            { "arg": "profile", "vals": ["synchronous"], "role": "client" },
            { "arg": "duration", "vals": ["60"], "role": "client" },
            { "arg": "input-tokens", "vals": ["128"], "role": "client" },
            { "arg": "output-tokens", "vals": ["64"], "role": "client" },
            { "arg": "tensor-parallel-size", "vals": ["1"], "role": "server" },
            { "arg": "port", "vals": ["8000"], "role": "server" }
        ],
        "gpu-full": [
            { "arg": "server-mode", "vals": ["vllm"], "role": "server" },
            { "arg": "device", "vals": ["cuda"], "role": "server" },
            { "arg": "model", "vals": ["meta-llama/Llama-3.1-8B-Instruct"], "role": "all" },
            { "arg": "dtype", "vals": ["auto"], "role": "server" },
            { "arg": "max-model-len", "vals": ["4096"], "role": "server" },
            { "arg": "profile", "vals": ["sweep"], "role": "client" },
            { "arg": "rate", "vals": ["10"], "role": "client" },
            { "arg": "duration", "vals": ["30"], "role": "client" },
            { "arg": "input-tokens", "vals": ["512"], "role": "client" },
            { "arg": "output-tokens", "vals": ["256"], "role": "client" },
            { "arg": "tensor-parallel-size", "vals": ["1"], "role": "server" },
            { "arg": "port", "vals": ["8000"], "role": "server" }
        ]
    },
    "validations": {
        "server_mode": {
            "description": "server mode: vllm (real inference) or mock (lightweight smoke)",
            "args": ["server-mode"],
            "vals": "^vllm$|^mock$"
        },
        "device_type": {
            "description": "inference device: cpu or cuda",
            "args": ["device"],
            "vals": "^cpu$|^cuda$"
        },
        "profile_type": {
            "description": "GuideLLM benchmark profile",
            "args": ["profile"],
            "vals": "^synchronous$|^concurrent$|^throughput$|^constant$|^poisson$|^sweep$"
        },
        "positive_integer": {
            "description": "a whole number greater than 0",
            "args": [
                "duration",
                "rate",
                "max-requests",
                "input-tokens",
                "output-tokens",
                "max-model-len",
                "tensor-parallel-size",
                "port"
            ],
            "vals": "[1-9][0-9]*"
        },
        "model_path": {
            "description": "a HuggingFace model ID or local path",
            "args": ["model"],
            "vals": ".+"
        },
        "dtype": {
            "description": "model data type",
            "args": ["dtype"],
            "vals": "^auto$|^float16$|^bfloat16$|^float32$"
        },
        "quantization": {
            "description": "quantization method",
            "args": ["quantization"],
            "vals": "^awq$|^gptq$|^fp8$|^none$"
        },
        "positive_float": {
            "description": "a floating point number between 0 and 1",
            "args": ["gpu-memory-utilization"],
            "vals": "^0?\\.[0-9]+$|^1\\.0$"
        }
    }
}
